# Copy this file to `.env` and fill in your values.

# Get a free API key at https://finnhub.io/register
FINNHUB_API_KEY=

# Starting cash for a brand-new account, in integer cents.
# 10000000 = $100,000.00
STARTING_CASH_CENTS=10000000

# Where the SQLite database lives. Relative to the backend/ directory.
DB_PATH=./data/market_sim.db
